# IHL local/user env template
# - ユーザーが編集するファイル（デバイス・ローカル運用値）。
# - .env.local にコピーして使用（コミット禁止）。

# ---------- local dev ----------
# Local dev and Playwright E2E only (NOT production)
IHL_DEV_EXPOSE_MAGIC_TOKEN=1
IHL_API_URL=http://api:8000

# ver3 auth gates (local default: auth OFF for API · middleware ON for Web)
# IHL_AUTH_REQUIRED=1
# IHL_AUTH_BYPASS=1
# IHL_WEB_AUTH_BYPASS=1

# embedding backend (local override)
# IHL_EMBEDDING_BACKEND=dummy

# ---------- collector (SwitchBot / ingest) ----------
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=
SWITCHBOT_DEVICE_IDS=

# collector signing private key (Ed25519 private key PEM in base64, single line)
ENV_COLLECTOR_PRIVATE_KEY_PEM_BASE64=

# ingest target / actor
CIV_INGEST_URL=http://host.docker.internal:8000/api/env/ingest
CIV_COLLECTOR_ID=local
CIV_USER_ID=20260414-ITHL-Herc-Labo-ratoryOS

# derived or optional public key fields
# ENV_COLLECTOR_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# ENV_COLLECTOR_PUBLIC_KEYS_JSON={"local":{"public_key_pem":"-----BEGIN PUBLIC KEY-----..."}}
# ENV_COLLECTOR_USER_ID=20260414-ITHL-Herc-Labo-ratoryOS

ENV_PLACEMENT_ID=
ENV_ANNOTATION_ID=
COLLECTOR_INTERVAL_SEC=300
COLLECTOR_LOCAL_PORT=8787
COLLECTOR_QUEUE_FILE=/data/queue.jsonl

# NEXT_PUBLIC_* を使う場合はここに置く（公開値のみ）
# NEXT_PUBLIC_FEATURE_FLAG_EXAMPLE=
