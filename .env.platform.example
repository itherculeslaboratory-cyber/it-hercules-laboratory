# IHL platform/infra env template
# - 管理者/デプロイ担当向け。通常ユーザーは編集しない。
# - VPS では .env.platform にコピーして使用（コミット禁止）。
# - ver3 本番: docs/vps-api-deploy.md · docs/ver3-deploy-runbook.md

# ---------- R2 / storage (production) ----------
R2_ENDPOINT=https://a49c9c8e4765257a0b07a7ef82eba550.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=it-hercules-laboratory-prod
R2_IHL_BUCKET=it-hercules-laboratory-prod
# 本番では IHL_R2_LOCAL_ROOT を設定しない（ローカル fallback 禁止）

# ---------- API / auth (production) ----------
IHL_AUTH_REQUIRED=1
IHL_CORS_ORIGINS=https://it-hercules.uk
# IHL_AUTH_BYPASS=1          # 本番禁止
# IHL_DEV_EXPOSE_MAGIC_TOKEN=1 # 本番禁止

# ---------- magic link email (same names as civ-os Express backend/.env) ----------
# SMTP_HOST 未設定 → メール送信なし（dev 相当）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=app_password_here
# MAIL_FROM=IT Hercules Laboratory <you@example.com>
# PUBLIC_APP_URL=https://it-hercules.uk
# IHL_MAGIC_LINK_BASE_URL=https://it-hercules.uk
# MAGIC_LINK_MAIL_SUBJECT=IT Hercules Laboratory — ログインリンク

# ---------- Cloudflare account/admin ----------
CF_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=a49c9c8e4765257a0b07a7ef82eba550

# ---------- GMO (admin gate only) ----------
# 正本: 05-運用/runbooks/gmo-env-when-ready.md
# Tier 0 (stub): すべて未設定でも可
# Tier 1 (stg): STG鍵を設定
# Tier 2 (live): 人間ゲート完了後のみ設定

# GMO_AOZORA_CLIENT_ID=
# GMO_AOZORA_CLIENT_SECRET=
# GMO_AOZORA_WEBHOOK_BASE_URL=https://api.gmo-aozora.com/ganb/api/webhooks/v1
# GMO_AOZORA_WEBHOOK_SECRET=
# GMO_AOZORA_WEBHOOK_SIGNATURE_HEADER=
# GMO_WEBHOOK_SIGNATURE_FORMAT=hex
# GMO_WEBHOOK_SIGNATURE_PREFIX=
# GMO_RECONCILIATION_STORE_PATH=
# GMO_LEDGER_SETTLEMENT=0
# GMO_YEN_PER_PLATINUM=100
# GMO_CONNECTOR_MODE=stub

# ---------- internal/admin optional ----------
# GITHUB_TOKEN=
