# IHL Phase 2 — Next.js web (standalone)
FROM node:22-bookworm-slim AS deps
WORKDIR /app
COPY apps/web/package.json ./
RUN npm install

FROM node:22-bookworm-slim AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY apps/web/ ./
ENV NEXT_TELEMETRY_DISABLED=1
ENV IHL_API_URL=http://api:8000
RUN npm run build

FROM node:22-bookworm-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV IHL_API_URL=http://api:8000
RUN groupadd --gid 1000 ihl && useradd --uid 1000 --gid ihl --create-home ihl
COPY --from=builder /app/public ./public
COPY --from=builder --chown=ihl:ihl /app/.next/standalone ./
COPY --from=builder --chown=ihl:ihl /app/.next/static ./.next/static
USER ihl
EXPOSE 3000
CMD ["node", "server.js"]
